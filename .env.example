# API Keys (replace with your actual keys)
# Note: Google API has a 28-day limit before it resets
GOOGLE_API_KEY=your_google_api_key_here
MISTRAL_API_KEY=your_mistral_api_key_here

# Ollama Configuration
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b

# AI Provider Load Balancing
AI_PROVIDERS=google,ollama,mistral
AI_REQUESTS_PER_PROVIDER=2
AI_ROTATION_ENABLED=true

# Database
DATABASE_URL=postgresql://lumerakai:secure_password@postgres:5432/lumerakai_health
REDIS_URL=redis://redis:6379

# FHIR Server
FHIR_SERVER_URL=http://fhir-server:8080/fhir

# Environment
NODE_ENV=development

# Security and Compliance
ENCRYPTION_KEY=generate_32_byte_key_here
AUDIT_LOG_LEVEL=info
HIPAA_COMPLIANCE_MODE=true